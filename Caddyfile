# Main app — static PWA served from /srv/hurryapp
hurryapp.id {
    root * /srv/hurryapp
    encode gzip
    try_files {path} {path}/ /index.html
    file_server

    # Always-fresh entry points so PWA updates roll out.
    # The service worker handles asset versioning, but only if its own
    # file (sw.js) and the HTML shell aren't cached aggressively.
    @fresh path / /index.html /sw.js /manifest.json
    header @fresh Cache-Control "no-cache"

    # Icons rarely change — let browsers hold them for a day.
    @assets path *.png *.svg
    header @assets Cache-Control "public, max-age=86400"
}

# www → apex
www.hurryapp.id {
    redir https://hurryapp.id{uri} permanent
}

# Baskara — reverse-proxied to its containers on shared caddy_net
baskara.hurryapp.id {
    encode gzip

    handle /api/* {
        reverse_proxy baskara-backend:8000
    }
    handle /health {
        reverse_proxy baskara-backend:8000
    }
    handle {
        reverse_proxy baskara-frontend:80
    }
}

# Raw IP over HTTP → hurryapp.id (no TLS for IP, that's fine)
http://165.22.96.5 {
    redir https://hurryapp.id{uri} permanent
}
