# Main app — static PWA served from /srv/hurryapp
hurryapp.id {
    root * /srv/hurryapp
    encode gzip
    try_files {path} {path}/ /index.html
    file_server

    # Always-fresh entry points so PWA updates roll out.
    # The service worker handles asset versioning, but only if its own
    # file (sw.js) and the HTML shell aren't cached aggressively.
    @fresh path / /index.html /sw.js /manifest.json
    header @fresh Cache-Control "no-cache"

    # Icons rarely change — let browsers hold them for a day.
    @assets path *.png *.svg
    header @assets Cache-Control "public, max-age=86400"

    # Anonymous event beacon. Client posts to /log?e=...&s=...&t=...
    # The query string is captured by the access log below; body is dropped.
    @beacon path /log
    handle @beacon {
        respond 204
    }

    # Access log persisted to disk with anything identifying stripped:
    # IPs, ports, all request headers (User-Agent, Cookie, Accept-Language…),
    # TLS fingerprint, response headers. What's left is method, URI, status,
    # size, duration — enough to see beacon events without tracking users.
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format filter {
            wrap json
            fields {
                request>remote_ip delete
                request>remote_port delete
                request>client_ip delete
                request>headers delete
                request>tls delete
                resp_headers delete
                user_id delete
            }
        }
    }
}

# www → apex
www.hurryapp.id {
    redir https://hurryapp.id{uri} permanent
}

# Baskara — reverse-proxied to its containers on shared caddy_net
baskara.hurryapp.id {
    encode gzip

    handle /api/* {
        reverse_proxy baskara-backend:8000
    }
    handle /health {
        reverse_proxy baskara-backend:8000
    }
    handle {
        reverse_proxy baskara-frontend:80
    }
}

# Raw IP over HTTP → hurryapp.id (no TLS for IP, that's fine)
http://165.22.96.5 {
    redir https://hurryapp.id{uri} permanent
}
